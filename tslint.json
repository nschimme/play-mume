{
  "defaultSeverity": "error",
  "extends": [
    "tslint:recommended"
  ],
  "jsRules": {},
  "rules": {
    "no-console": false,
    "max-classes-per-file": false,
    "only-arrow-functions": false,
    "variable-name": false,
    "no-namespace": false,
    "one-variable-per-declaration": false,
    "prefer-for-of": false,
    "no-conditional-assignment": false
  },
  "rulesDirectory": []
}
